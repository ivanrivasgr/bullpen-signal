# Copy to .env and adjust
# ---

# Kafka / Redpanda
KAFKA_BOOTSTRAP_SERVERS=localhost:19092
KAFKA_SCHEMA_REGISTRY_URL=http://localhost:18081

# Topics
TOPIC_PITCHES_RAW=pitches.raw
TOPIC_GAME_STATE_RAW=game_state.raw
TOPIC_CORRECTIONS_CDC=corrections.cdc
TOPIC_ALERTS=alerts.v1
TOPIC_FATIGUE=features.fatigue.v1
TOPIC_LEVERAGE=features.leverage.v1
TOPIC_MATCHUP=features.matchup.v1

# MinIO / S3
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1
S3_BUCKET_LAKEHOUSE=bullpen-lakehouse

# Iceberg catalog
ICEBERG_CATALOG_URI=http://localhost:8181
ICEBERG_WAREHOUSE=s3://bullpen-lakehouse/warehouse

# Flink
FLINK_JOBMANAGER_URL=http://localhost:8082

# Replay engine defaults
REPLAY_DEFAULT_SPEED=5
REPLAY_NOISE_LATE_ARRIVAL_PROB=0.03
REPLAY_NOISE_DUPLICATE_PROB=0.005
REPLAY_NOISE_CORRECTION_PROB=0.01

# Observability
LOG_LEVEL=INFO
